<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SS" parent="Theme.MaterialComponents.Light">
        <!-- Primary brand color. -->
        <item name="android:colorAccent">@color/teal_200</item>
        <item name="isMaterialTheme">true</item>
        <item name="colorPrimary">@color/purple_200</item>
        <item name="android:statusBarColor">@color/purple_200</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimaryVariant">@color/teal_700</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceContainer">@color/purple_200</item>
        <item name="android:actionModeWebSearchDrawable">@drawable/ic_search_black_24dp</item>
        <item name="android:homeAsUpIndicator">@drawable/prev</item>
        <item name="android:actionOverflowButtonStyle">@style/Theme.SS.OverflowMenu</item>
        <item name="android:searchViewStyle">@style/SSs</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.SS.ProPre" parent="Theme.SS">
        <item name="android:statusBarColor">?android:colorBackground</item>
        <item name="colorPrimary">?android:colorBackground</item>
    </style>

    <style name="Theme.SS.Pro" parent="Theme.SS">
        <!-- Primary brand color. -->
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowOverscan">true</item>
        <item name="android:immersive">true</item>
        <item name="android:windowActionBar">true</item>
        <!-- Indicate that the window is translucent -->
        <!-- Optional: set status and navigation bars to transparent for a full-screen effect -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="SSs" parent="android:Widget.Material.Light.SearchView">
        <item name="android:closeIcon">@drawable/close</item>
        <item name="android:searchIcon">@drawable/ic_search_black_24dp</item>
        <item name="android:goIcon">@drawable/next</item>
    </style>
    <style name="Theme.C" parent="Theme.SS"/>


    <style name="Theme.SS.OverflowMenu" parent="Widget.AppCompat.Light.ActionButton">
        <item name="android:src">@drawable/more</item>
    </style>


    <style name="SS.KeyboardView" parent="android:Widget">
        <item name="android:background">?android:colorBackground</item>
        <item name="android:keyBackground">?android:textColorPrimaryInverseDisableOnly</item>
        <item name="android:keyPreviewLayout">@layout/k_preview</item>
        <item name="android:keyTextSize">22sp</item>
        <item name="android:keyTextColor">?android:textColorPrimary</item>
        <item name="android:keyPreviewHeight">80dip</item>
        <item name="android:labelTextSize">14sp</item>
    </style>
</resources>