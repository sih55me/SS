<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SS" parent="Theme.Notds">
        <item name="android:actionModeWebSearchDrawable">@drawable/search</item>
        <!-- Customize your theme here. -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>





    <style name="Theme.SS.ProPre" parent="Theme.SS">
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="Theme.SS.Pro" parent="Theme.SS">
        <!-- Primary brand color. -->
<!--        <item name="android:windowIsFloating">true</item>-->
<!--        <item name="android:windowIsTranslucent">true</item>-->
<!--        <item name="android:windowBackground">@android:color/transparent</item>-->
<!--        <item name="android:windowOverscan">true</item>-->
<!--        <item name="android:immersive">true</item>-->
<!--        <item name="android:windowNoTitle">true</item>-->
<!--        &lt;!&ndash; Indicate that the window is translucent &ndash;&gt;-->
<!--        &lt;!&ndash; Optional: set status and navigation bars to transparent for a full-screen effect &ndash;&gt;-->
<!--        <item name="android:statusBarColor">@android:color/transparent</item>-->
<!--        <item name="android:navigationBarColor">@android:color/transparent</item>-->
        <!-- Customize your theme here. -->
    </style>
    <style name="WTheme.SS.AM" parent="android:Widget.Material">
        <item name="android:actionOverflowMenuStyle">@style/WTheme.SS.OverflowMenu</item>
        <item name="android:actionButtonStyle">@style/WTheme.SS.AC</item>
        <item name="android:popupTheme">@style/WTheme.SS.Pop</item>
    </style>
    <style name="WTheme.SS.Pop" parent="android:Widget.Material.PopupMenu">
        <item name="android:popupAnimationStyle">@null</item>
        <item name="android:popupEnterTransition">@android:transition/slide_bottom</item>
        <item name="android:popupExitTransition">@android:transition/slide_bottom</item>
        <item name="android:popupBackground">@android:drawable/toast_frame</item>
    </style>
    <style name="Theme.SS.PP" parent="Theme.SS">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowSwipeToDismiss">true</item>
    </style>
    <style name="SSs" parent="android:Widget.Material.SearchView">
        <item name="android:closeIcon">@drawable/close</item>
        <item name="android:searchIcon">@drawable/search</item>
        <item name="android:commitIcon">@drawable/next</item>
        <item name="android:goIcon">@drawable/next</item>
    </style>
    <style name="Theme.C" parent="Theme.SS"/>
    <style name="WTheme.SS.AC" parent="android:Widget.Holo.Button.Borderless">

        <item name="android:minWidth">50dp</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:gravity">center</item>
        <item name="android:scaleType">center</item>
        <item name="android:maxLines">2</item>
    </style>

    <style name="WTheme.SS.OverflowMenu" parent="android:Widget.Material.ActionButton.Overflow">
        <item name="android:src">@drawable/more</item>
    </style>


    <style name="SS.KeyboardView" parent="android:Widget">
        <item name="android:keyBackground">@drawable/full_frame</item>
        <item name="android:keyPreviewLayout">@layout/k_preview</item>
        <item name="android:keyTextSize">22sp</item>
        <item name="android:keyTextColor">?android:textColorPrimary</item>
        <item name="android:keyPreviewHeight">80dip</item>
        <item name="android:labelTextSize">14sp</item>
    </style>
</resources>