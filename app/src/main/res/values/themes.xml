<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SS" parent="android:Theme.Material.Light.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="android:colorPrimary">#2196F3</item>
        <item name="android:colorPrimaryDark">@color/purple_700</item>
        <item name="android:statusBarColor">?android:attr/colorPrimary</item>
        <item name="android:homeAsUpIndicator">@drawable/back_nav</item>
        <item name="android:colorAccent">#274681</item>
        <item name="android:colorControlNormal">#99000000</item>
        <item name="android:actionOverflowButtonStyle">@style/Theme.SS.OverflowMenu</item>
        <item name="android:actionModeWebSearchDrawable">@drawable/search</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.C" parent="Theme.SS"/>

    <style name="Theme.SS.OverflowMenu" parent="android:Widget.Material.Light.ActionButton.Overflow">
        <item name="android:src">@drawable/more</item>
    </style>
</resources>