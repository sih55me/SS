<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Notds" parent="android:Theme.Material">
        <item name="android:actionModeCloseDrawable">@drawable/back_nav</item>
        <item name="android:actionModeBackground">?android:colorBackground</item>
        <item name="android:toolbarStyle">@style/Widget.Notds.Toolbar</item>
        <item name="android:actionModeCloseButtonStyle">@style/Widget.Notds.ActionButton.CloseMode</item>
        <item name="android:actionOverflowButtonStyle">@style/Widget.Notds.ActionButton.Overflow</item>
        <item name="android:homeAsUpIndicator">@drawable/back_nav</item>
        <item name="android:actionBarSize">54dp</item>
        <item name="android:actionModeStyle">@style/Widget.Notds.ActionMode</item>
        <item name="android:buttonCornerRadius" tools:targetApi="28">20dp</item>
        <item name="android:dialogTheme">@style/Theme.Notds.Dialog</item>
        <item name="android:popupTheme">?android:popupMenuStyle</item>
        <item name="android:popupMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:contextPopupMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:actionOverflowMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:windowBackground">@drawable/full_frame</item>
        <item name="android:alertDialogTheme">@style/Theme.Notds.Dialog</item>
        <item name="android:buttonStyle">@style/Widget.Notds.Button</item>
        <item name="android:checkboxStyle">@style/Widget.Notds.Checkbox</item>
        <item name="android:radioButtonStyle">@style/Widget.Notds.RadioButton</item>
        <!--color-->
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:colorButtonNormal">@color/colorBtn</item>
        <item name="android:colorSecondary">@color/black</item>
        <item name="android:colorPrimary">@color/colorPrimaryN</item>
        <item name="android:colorPrimaryDark">@color/colorPrimaryDN</item>
        <item name="android:colorAccent">@color/colorAccentN</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>




    <style name="Widget.Notds.PopupMenu" parent="android:Widget.Material.PopupMenu">
        <!-- Background color -->
        <item name="android:popupBackground">@drawable/dialog_menu_frame</item>
        <!-- Text color -->
        <item name="android:textColorPrimary">?android:colorAccent</item>
        <item name="android:textColor">?android:colorAccent</item>
        <!-- Item background -->
        <!-- Divider -->
        <item name="android:divider">@color/black</item>
        <item name="android:dividerHeight">1dp</item>
    </style>



    <style name="ATR" parent="android:Animation.Activity">
        <item name="android:windowEnterAnimation">?android:taskOpenEnterAnimation</item>
        <item name="android:windowExitAnimation">?android:taskCloseExitAnimation</item>
    </style>


    <style name="Theme.Notds.Dialog" parent="android:Theme.Material.Dialog.Alert">
        <!--color-->
        <item name="android:actionModeCloseDrawable">@drawable/back_nav</item>
        <item name="android:toolbarStyle">@style/Widget.Notds.Toolbar</item>
        <item name="android:actionModeCloseButtonStyle">@style/Widget.Notds.ActionButton.CloseMode</item>
        <item name="android:actionOverflowButtonStyle">@style/Widget.Notds.ActionButton.Overflow</item>
        <item name="android:homeAsUpIndicator">@drawable/back_nav</item>
        <item name="android:actionBarSize">54dp</item>
        <item name="android:actionModeBackground">?android:attr/actionModeSplitBackground</item>
        <item name="android:actionModeStyle">@style/Widget.Notds.ActionMode</item>
        <item name="*android:actionModePopupWindowStyle">@null</item>
        <item name="android:dialogTheme">@style/Theme.Notds.Dialog</item>
        <item name="android:popupTheme">?android:popupMenuStyle</item>
        <item name="android:popupMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:contextPopupMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:actionOverflowMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:windowBackground">@drawable/dialog_frame</item>
        <item name="android:alertDialogTheme">@style/Theme.Notds.Dialog</item>
        <item name="android:buttonStyle">@style/Widget.Notds.Button</item>
        <item name="android:checkboxStyle">@style/Widget.Notds.Checkbox</item>
        <item name="android:radioButtonStyle">@style/Widget.Notds.RadioButton</item>
        <!--color-->
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:colorButtonNormal">@color/colorBtn</item>
        <item name="android:colorSecondary">@color/black</item>
        <item name="android:colorPrimary">@color/colorPrimaryN</item>
        <item name="android:colorPrimaryDark">@color/colorPrimaryDN</item>
        <item name="android:colorAccent">@color/colorAccentN</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/Widget.Notds.ButtonDialog.Ok</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/Widget.Notds.ButtonDialog.No</item>
        <item name="android:buttonBarNeutralButtonStyle">@style/Widget.Notds.ButtonDialog.No</item>
        <item name="android:buttonCornerRadius" tools:targetApi="28">20dp</item>
        <item name="android:windowTitleStyle">@android:style/TextAppearance.Material.Large</item>
        <item name="android:windowMinWidthMajor">90dp</item>
        <item name="android:windowMinWidthMinor">30dp</item>

    </style>

    <style name="Widget.Notds.ButtonDialog.Ok" parent="android:Widget.Material.Button">
        <item name="android:backgroundTint">?android:colorAccent</item>
        <item name="android:elevation">0dp</item>
        <item name="android:textColor">?android:textColorPrimaryInverse</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">74dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:layout_margin">1.2dp</item>
    </style>

    <style name="Widget.Notds.Button" parent="android:Widget.Material.Button">
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.Notds.Checkbox" parent="android:Widget.Material.CompoundButton.CheckBox">
        <item name="android:button">?android:listChoiceIndicatorMultiple</item>
    </style>

    <style name="Widget.Notds.RadioButton" parent="android:Widget.Material.CompoundButton.RadioButton">
        <item name="android:button">?android:listChoiceIndicatorSingle</item>
    </style>

    <style name="Widget.Notds.ButtonDialog.No" parent="Widget.Notds.ButtonDialog.Ok">

        <item name="android:textColor">?android:textColorPrimary</item>
        <item name="android:backgroundTint">#44C8C8C8</item>
    </style>





    <style name="Theme.Notds.AltTab" parent="Theme.Notds">
        <item name="android:windowIsTranslucent">true</item>
    </style>
    <style name="Theme.Notds.Search" parent="Theme.Notds.Dialog">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:actionModeBackground">?android:colorBackground</item>
        <item name="android:windowActionBar">true</item>
        <item name="android:windowBackground">@drawable/full_frame</item>
    </style>

    <style name="Theme.Notds.InfoNote" parent="Theme.Notds.Dialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:actionModeBackground">?android:colorBackground</item>
        <item name="android:windowActionBar">true</item>
    </style>



    <style name="SS.KeyboardView" parent="android:Widget">
        <item name="android:keyBackground">@drawable/full_frame</item>
        <item name="android:keyPreviewLayout">@layout/k_preview</item>
        <item name="android:keyTextSize">22sp</item>
        <item name="android:keyTextColor">?android:textColorPrimary</item>
        <item name="android:keyPreviewHeight">80dip</item>
        <item name="android:labelTextSize">14sp</item>
    </style>



</resources>