<?xml version="1.0" encoding="utf-8"?>

<resources xmlns:tools="http://schemas.android.com/tools">

    <fraction name="buttonDialogMargin">1.2dp</fraction>
    <style name="Widget.Notds.Toolbar" parent="android:Widget.Material.Toolbar">
        <item name="android:titleTextAppearance">@android:style/TextAppearance.Material.Large</item>
        <item name="android:subtitleTextAppearance">@android:style/TextAppearance.Material.Small</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:contentInsetStart">0dp</item>
        <item name="android:contentInsetEnd">0dp</item>
        <item name="android:popupMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:maxButtonHeight" tools:ignore="NewApi">48dp</item>
    </style>
    <style name="Widget.Notds.ActionMode" parent="android:Widget.Material.ActionMode">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:popupMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:contentInsetEnd">0dp</item>
        <item name="android:contentInsetStart">0dp</item>
    </style>
    <style name="Widget.Notds.Actionbar" parent="@android:style/Widget.Material.ActionBar">
        <item name="android:titleTextAppearance">@null</item>
        <item name="android:contentInsetStart">0dp</item>
        <item name="android:popupMenuStyle">@style/Widget.Notds.PopupMenu</item>
        <item name="android:contentInsetEnd">0dp</item>
    </style>

    <style name="Widget.Notds.ActionButton.CloseMode" parent="android:Widget.Material.ActionButton.CloseMode">
        <item name="android:paddingStart">5dp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:minWidth">48dp</item>

    </style>
    <style name="Widget.Notds.ActionButton.Overflow" parent="android:Widget.Material.ActionButton.Overflow">
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:src">@drawable/more</item>
    </style>

    <style name="Widget.Notds.Toolbar.Button.Navigation" parent="android:Widget.Material.Toolbar.Button.Navigation">
        <item name="android:minWidth">48dp</item>
    </style>
</resources>